{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/backend/app.js"
    },
    {
      "source": "/(.*)",
      "destination": "/frontend/index.html"
    }
  ],
  "functions": {
    "backend/app.js": {
      "runtime": "@vercel/node",
      "includeFiles": "backend/prompts/**"
    }
  }
}