{
  "version": 2,
  "builds": [
    {
      "src": "app.js",
      "use": "@vercel/node",
      "config": { "includeFiles": ["prompts/**", "routes/**"] }
    }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "app.js" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "ALLOWALL" },
        { 
          "key": "Content-Security-Policy", 
          "value": "frame-ancestors 'self' https://carter-portfolio.fyi https://carter-portfolio.vercel.app https://*.vercel.app http://localhost:3000 https://code-practice-nu.vercel.app" 
        }
      ]
    }
  ]
}